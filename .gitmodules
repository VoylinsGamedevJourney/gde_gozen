[submodule "FFmpeg"]
	path = ffmpeg
	url = https://github.com/FFmpeg/FFmpeg.git
	branch = release/7.1
	ignore = dirty
[submodule "godot-cpp"]
	path = godot_cpp
	url = https://github.com/godotengine/godot-cpp.git
	branch = 4.2
	ignore = dirty
[submodule "emsdk"]
	path = emsdk
	url = https://github.com/emscripten-core/emsdk.git
	ignore = dirty
[submodule "libvpx"]
	path = libvpx
	url = https://chromium.googlesource.com/webm/libvpx
	ignore = dirty
[submodule "libaom"]
	path = libaom
	url = https://aomedia.googlesource.com/aom
	ignore = dirty
